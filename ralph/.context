  src/assets/icons/cursor.svg
  src/app/pages/home/home.ts
  src/app/pages/home/home.html
  src/app/pages/home/star-field.ts (deleted)
  src/app/pages/home/star-field.spec.ts (deleted)

Unblocks #22 (HeroSectionComponent).

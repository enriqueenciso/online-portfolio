# Enforce pnpm as the only allowed package manager for this project.
# Running `npm install` or `yarn` will be blocked by the `packageManager`
# field in package.json (enforced by corepack / pnpm itself).
#
# Install pnpm: https://pnpm.io/installation
# Recommended: use the standalone installer or `corepack enable && corepack prepare pnpm@latest --activate`

# Keep Angular's generated files from being hoisted unexpectedly
shamefully-hoist=false

# Fail the install if the Node.js version doesn't satisfy engines field
engine-strict=false
